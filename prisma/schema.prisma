generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------
// Auth Models (NextAuth / Auth.js standard)
// ----------------------------------------

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roleId        String?
  employeeId    String?   @unique

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]
  approvedLeaves LeaveRequest[] @relation("LeaveApprover")

  role     Role?     @relation(fields: [roleId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // SUPER_ADMIN, HR_ADMIN, HR_MANAGER, MANAGER, SUPERVISOR, EMPLOYEE, AUDITOR
  description String?

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String  @id @default(uuid())
  action      String  @unique // e.g. "employee.read", "attendance.import"
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ----------------------------------------
// Audit Log
// ----------------------------------------

model AuditLog {
  id            String  @id @default(uuid())
  actorUserId   String?
  action        String // CREATE, UPDATE, DELETE, IMPORT, EXPORT, APPROVE
  entityType    String // Employee, Attendance, LeaveRequest, etc.
  entityId      String
  before        Json?
  after         Json?
  reason        String?
  ip            String?
  userAgent     String?
  correlationId String?

  actor     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ----------------------------------------
// Employee Master
// ----------------------------------------

enum EmploymentStatus {
  PROBATION
  CONTRACT
  PERMANENT
  FREELANCE
  LEAVE_OF_ABSENCE
  SUSPENDED
  RESIGNED
  TERMINATED
  CONTRACT_ENDED
}

model Employee {
  id               String           @id @default(uuid())
  employeeNumber   String           @unique
  attendancePin    String?          @unique
  fullName         String
  gender           String? // MALE, FEMALE
  email            String?          @unique
  employmentStatus EmploymentStatus @default(CONTRACT)
  joinDate         DateTime         @db.Date
  endDate          DateTime?        @db.Date
  workLocationId   String?

  user                User?
  rawLogs             AttendanceRawLog[]
  summaries           AttendanceDailySummary[]
  positionAssignments EmployeePositionAssignment[]
  contracts           EmploymentContract[]
  leaveRequests       LeaveRequest[]

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  employeeKpiAssignments EmployeeKpiAssignment[]

  @@index([employeeNumber])
}

// ----------------------------------------
// Organization Models
// ----------------------------------------

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes OrganizationNode[]
}

model OrganizationNode {
  id        String  @id @default(uuid())
  companyId String
  parentId  String?
  name      String
  type      String // e.g. "Department", "Division", "Unit"

  company  Company            @relation(fields: [companyId], references: [id])
  parent   OrganizationNode?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children OrganizationNode[] @relation("OrgHierarchy")

  positions Position[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobLevel {
  id   String @id @default(uuid())
  code String @unique // e.g. "L1", "L2", "EXECUTIVE"
  name String
  rank Int    @default(0) // For sorting

  positions Position[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id                 String  @id @default(uuid())
  organizationNodeId String
  jobLevelId         String
  reportsToId        String?
  name               String
  idealCount         Int     @default(1)
  status             String  @default("ACTIVE") // ACTIVE, INACTIVE

  node          OrganizationNode @relation(fields: [organizationNodeId], references: [id])
  jobLevel      JobLevel         @relation(fields: [jobLevelId], references: [id])
  reportsTo     Position?        @relation("PositionHierarchy", fields: [reportsToId], references: [id])
  directReports Position[]       @relation("PositionHierarchy")

  assignments EmployeePositionAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeePositionAssignment {
  id         String    @id @default(uuid())
  employeeId String
  positionId String
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  isPrimary  Boolean   @default(true)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([positionId])
}

model EmploymentContract {
  id           String    @id @default(uuid())
  employeeId   String
  contractType String // PERMANENT, CONTRACT, PROBATION
  startDate    DateTime  @db.Date
  endDate      DateTime? @db.Date
  documentUrl  String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}


// ----------------------------------------
// KPI Models
// ----------------------------------------

enum KpiCalculationType {
  HIGHER_BETTER
  LOWER_BETTER
  PERCENTAGE
  BOOLEAN
  MANUAL_SCORE
}

enum KpiStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AssignmentStatus {
  DRAFT
  IN_PROGRESS
  AWAITING_APPROVAL
  APPROVED
}

model KpiTemplate {
  id          String                  @id @default(uuid())
  name        String
  description String?
  isActive    Boolean                 @default(true)
  categories  KpiCategory[]
  assignments EmployeeKpiAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KpiCategory {
  id         String         @id @default(uuid())
  templateId String
  name       String
  weight     Decimal        @default(0) // Percentage of total KPI
  indicators KpiIndicator[]
  template   KpiTemplate    @relation(fields: [templateId], references: [id])
}

model KpiIndicator {
  id         String             @id @default(uuid())
  categoryId String
  name       String
  type       KpiCalculationType @default(HIGHER_BETTER)
  unit       String // e.g., "Percentage", "Count", "Currency"
  weight     Decimal // Weight within category
  penalty    Decimal            @default(0)
  category   KpiCategory        @relation(fields: [categoryId], references: [id])
  items      EmployeeKpiItem[]
}

model KpiPeriod {
  id          String                  @id @default(uuid())
  name        String // e.g., "Q1 2026"
  startDate   DateTime                @db.Date
  endDate     DateTime                @db.Date
  status      KpiStatus               @default(DRAFT)
  assignments EmployeeKpiAssignment[]
}

model EmployeeKpiAssignment {
  id                String           @id @default(uuid())
  employeeId        String
  templateId        String
  periodId          String
  totalPenaltyScore Decimal          @default(0)
  finalScore        Decimal?
  status            AssignmentStatus @default(DRAFT)

  employee Employee          @relation(fields: [employeeId], references: [id])
  template KpiTemplate       @relation(fields: [templateId], references: [id])
  period   KpiPeriod         @relation(fields: [periodId], references: [id])
  items    EmployeeKpiItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeKpiItem {
  id           String   @id @default(uuid())
  assignmentId String
  indicatorId  String
  target       Decimal
  actual       Decimal?
  score        Decimal?

  assignment EmployeeKpiAssignment @relation(fields: [assignmentId], references: [id])
  indicator  KpiIndicator          @relation(fields: [indicatorId], references: [id])
}

enum ScanType {
  IN
  OUT
  BREAK_IN
  BREAK_OUT
  UNKNOWN
}

enum AttendanceSource {
  FILE_IMPORT
  DEVICE_API
  WEBHOOK
  MANUAL_SYNC
}

enum AttendanceStatus {
  PRESENT
  LEAVE
  SICK
  PERMISSION
  WFH
  BUSINESS_TRIP
  ABSENT
  HOLIDAY
  OFF
}

enum LeaveType {
  CUTI_TAHUNAN
  CUTI_SAKIT
  IZIN
  CUTI_MELAHIRKAN
  CUTI_KHUSUS
}

enum LeaveStatus {
  MENUNGGU
  DISETUJUI
  DITOLAK
  DIBATALKAN
}

model AttendanceRawLog {
  id            String           @id @default(uuid())
  employeeId    String?
  employeePin   String
  scanAt        DateTime         @db.Timestamptz(3)
  scanType      ScanType         @default(UNKNOWN)
  deviceCode    String?
  source        AttendanceSource
  sourceHash    String           @unique
  rawPayload    Json?
  importBatchId String?

  employee Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeePin, scanAt])
  @@index([employeeId, scanAt])
}

model AttendanceDailySummary {
  id                 String           @id @default(uuid())
  employeeId         String
  workDate           DateTime         @db.Date
  scheduledIn        DateTime?        @db.Timestamptz(3)
  scheduledOut       DateTime?        @db.Timestamptz(3)
  actualCheckIn      DateTime?        @db.Timestamptz(3)
  actualCheckOut     DateTime?        @db.Timestamptz(3)
  lateMinutes        Int              @default(0)
  earlyLeaveMinutes  Int              @default(0)
  workedMinutes      Int              @default(0)
  overtimeMinutes    Int              @default(0)
  primaryStatus      AttendanceStatus
  exceptionFlags     String[] // e.g., ["LATE", "EARLY_LEAVE", "MISSING_CHECK_OUT"]
  calculationVersion String
  sourceSnapshot     Json?

  calculatedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, workDate])
  @@index([workDate, primaryStatus])
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  durationDays Int
  reason      String      @db.Text
  documentUrl String?
  status      LeaveStatus @default(MENUNGGU)
  rejectReason String?    @db.Text
  approverId  String?
  approvedAt  DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver User?    @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
}

# Database (required)
# Example Supabase pooler: postgresql://postgres.[ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/hrd_quantum

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Optional
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_MINIO_ENDPOINT=http://localhost:9095
